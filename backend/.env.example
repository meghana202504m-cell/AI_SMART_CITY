# Smart City AI Backend - Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# ==================== GOOGLE MAPS API ====================
# Get your API key from: https://console.cloud.google.com
# Enable: Geocoding API, Places API, Directions API
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ==================== WEATHER API ====================
# Get your API key from: https://openweathermap.org/api
# Free tier provides current weather and 5-day forecast
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY_HERE

# ==================== JWT AUTHENTICATION ====================
# Generate a strong secret key for JWT token signing
# In production, use a cryptographically secure random value
# Example: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345

# ==================== EMAIL CONFIGURATION ====================
# Used for sending municipal alerts to authorities
# Gmail example: Use App Password, not your regular password
# Get App Password: https://myaccount.google.com/apppasswords

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=smartcity@gmail.com
SENDER_PASSWORD=your_app_password_here_not_regular_password

# Alternative: Use Outlook
# SMTP_SERVER=smtp-mail.outlook.com
# SMTP_PORT=587
# SENDER_EMAIL=yourname@outlook.com
# SENDER_PASSWORD=your_outlook_password

# ==================== DATABASE CONFIGURATION ====================
# Optional: MongoDB connection for production
# If not set, the app falls back to JSON file storage
# Format: mongodb://username:password@host:port/database

MONGO_URI=mongodb://localhost:27017/smart_city
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/smart_city

# ==================== DEVELOPMENT SETTINGS ====================
# Set to 'development' for detailed error messages
# Set to 'production' for security hardening
ENVIRONMENT=development

# ==================== FILE STORAGE ====================
# These are auto-created if not present
# DATA_DIR=./data
# UPLOADS_DIR=./data/uploads
